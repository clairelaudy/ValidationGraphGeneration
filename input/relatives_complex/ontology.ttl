@prefix : <http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/> .

<http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/childOf
:childOf rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :isRelative ;
         owl:inverseOf :parentOf ;
         rdfs:domain :Person ;
         rdfs:range :Person ;
         rdfs:label "childOf" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/daugtherOf
:daugtherOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :childOf ;
            rdfs:domain :Female ;
            rdfs:range :Person ;
            rdfs:label "daugtherOf" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/hasPartner
:hasPartner rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :isRelative ;
            rdfs:domain :Person ;
            rdfs:range :Person ;
            rdfs:label "hasPartner" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/hasPet
:hasPet rdf:type owl:ObjectProperty ;
        rdfs:domain :Person ;
        rdfs:range :Animal .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/hasRole
:hasRole rdf:type owl:ObjectProperty ;
         rdfs:domain :Person ;
         rdfs:range :Role .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/isRelative
:isRelative rdf:type owl:ObjectProperty ;
            rdfs:domain :Person ;
            rdfs:range :Person .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/parentOf
:parentOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :isRelative ;
          rdfs:domain :Person ;
          rdfs:range :Person ;
          rdfs:label "parentOf" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/siblingOf
:siblingOf rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :isRelative ;
           rdfs:domain :Person ;
           rdfs:range :Person ;
           rdfs:label "siblingOf" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/sonOf
:sonOf rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :childOf ;
       rdfs:domain :Male ;
       rdfs:range :Person ;
       rdfs:label "sonOf" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Animal
:Animal rdf:type owl:Class ;
        rdfs:subClassOf :Biocypherroot ;
        rdfs:label "animal" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Biocypherroot
:Biocypherroot rdf:type owl:Class ;
               rdfs:label "Biocypherroot" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Cat
:Cat rdf:type owl:Class ;
     rdfs:subClassOf :Animal ;
     rdfs:label "cat" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Dog
:Dog rdf:type owl:Class ;
     rdfs:subClassOf :Animal ;
     rdfs:label "dog" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Female
:Female rdf:type owl:Class ;
        rdfs:subClassOf :Person ;
        rdfs:label "female" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Male
:Male rdf:type owl:Class ;
      rdfs:subClassOf :Person ;
      rdfs:label "male" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Biocypherroot ;
        rdfs:label "person" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/Role
:Role rdf:type owl:Class ;
      rdfs:subClassOf :Biocypherroot ;
      rdfs:label "role" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/hasPet
:hasPet rdf:type owl:Class ;
        rdfs:subClassOf :Biocypherroot .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/hasRole
:hasRole rdf:type owl:Class ;
         rdfs:subClassOf :Biocypherroot .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/isRelative
:isRelative rdf:type owl:Class ;
            rdfs:subClassOf :Biocypherroot .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/parent
:parent rdf:type owl:NamedIndividual ,
                 :Role ;
        rdfs:label "parent" .


###  http://www.semanticweb.org/claudy/ontologies/2025/10/untitled-ontology-3/sibling
:sibling rdf:type owl:NamedIndividual ,
                  :Role ;
         rdfs:label "sibling" .


[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean
] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean
 ] .

#################################################################
#    Annotations
#################################################################

:hasPet rdfs:label "hasPet" .


:hasRole rdfs:label "hasRole" .


:isRelative rdfs:label "isRelative" .


#################################################################
#    Rules
#################################################################

:p rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:c1 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:c2 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "sibling rule" ;
   rdfs:label "siblingOf" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Person ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :p
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :parentOf ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :p ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :c1
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :parentOf ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :p ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :c2
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :siblingOf ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :c1 ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :c2
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :siblingOf ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :c2 ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :c1
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ]
 ] .

[ rdfs:comment "" ;
   rdfs:label "parent" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Person ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :p
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :parentOf ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :p ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :c
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRole ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :p ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :parent
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

